# Supabase
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-seitiger Supabase-Zugriff (optional, umgeht RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === Raumübersicht API (Dashboard-Integration) ===

# API-Key für die Authentifizierung der Dashboard-Anfragen
# Muss im Dashboard als BLITZ_PROTOKOLL_API_KEY konfiguriert werden
BLITZ_API_KEY=your-secret-api-key

# Erlaubte Origin für CORS (Dashboard-URL)
# Auf * setzen für Entwicklung, in Produktion die echte Dashboard-URL
BLITZ_API_ALLOWED_ORIGIN=*

# Webhook-URL des Dashboards (optional)
# Wird aufgerufen wenn sich die Planung ändert
# Format: POST mit { "event": "planung_updated", "datum": "2026-03-17" }
BLITZ_WEBHOOK_URL=https://your-dashboard.netlify.app/api/blitz-webhook

# Secret für Supabase Database Webhooks (optional)
# Wird als x-webhook-secret Header von Supabase gesendet
SUPABASE_WEBHOOK_SECRET=your-webhook-secret
